{
  "note": "Cyrillic reference for the refresher track. group is one of familiar, false_friend, new. anchor is an English sound cue. Order follows the Russian alphabet.",
  "letters": [
    { "upper": "А", "lower": "а", "sound": "a", "anchor": "a in father", "group": "familiar" },
    { "upper": "Б", "lower": "б", "sound": "b", "anchor": "b in bat", "group": "new" },
    { "upper": "В", "lower": "в", "sound": "v", "anchor": "v in vine, looks like a Latin B", "group": "false_friend" },
    { "upper": "Г", "lower": "г", "sound": "g", "anchor": "g in go", "group": "new" },
    { "upper": "Д", "lower": "д", "sound": "d", "anchor": "d in dog", "group": "new" },
    { "upper": "Е", "lower": "е", "sound": "ye", "anchor": "ye in yes, looks like a Latin E", "group": "false_friend" },
    { "upper": "Ё", "lower": "ё", "sound": "yo", "anchor": "yo in yonder, always stressed", "group": "new" },
    { "upper": "Ж", "lower": "ж", "sound": "zh", "anchor": "s in pleasure", "group": "new" },
    { "upper": "З", "lower": "з", "sound": "z", "anchor": "z in zoo", "group": "new" },
    { "upper": "И", "lower": "и", "sound": "ee", "anchor": "ee in see", "group": "new" },
    { "upper": "Й", "lower": "й", "sound": "y", "anchor": "y in boy, a short glide", "group": "new" },
    { "upper": "К", "lower": "к", "sound": "k", "anchor": "k in kit", "group": "familiar" },
    { "upper": "Л", "lower": "л", "sound": "l", "anchor": "l in lamp", "group": "new" },
    { "upper": "М", "lower": "м", "sound": "m", "anchor": "m in map", "group": "familiar" },
    { "upper": "Н", "lower": "н", "sound": "n", "anchor": "n in no, looks like a Latin H", "group": "false_friend" },
    { "upper": "О", "lower": "о", "sound": "o", "anchor": "o in more when stressed, reduces to a when not", "group": "familiar" },
    { "upper": "П", "lower": "п", "sound": "p", "anchor": "p in pen", "group": "new" },
    { "upper": "Р", "lower": "р", "sound": "r", "anchor": "rolled r, looks like a Latin P", "group": "false_friend" },
    { "upper": "С", "lower": "с", "sound": "s", "anchor": "s in sun, looks like a Latin C", "group": "false_friend" },
    { "upper": "Т", "lower": "т", "sound": "t", "anchor": "t in top", "group": "familiar" },
    { "upper": "У", "lower": "у", "sound": "oo", "anchor": "oo in boot, looks like a Latin Y", "group": "false_friend" },
    { "upper": "Ф", "lower": "ф", "sound": "f", "anchor": "f in fan", "group": "new" },
    { "upper": "Х", "lower": "х", "sound": "kh", "anchor": "ch in loch, looks like a Latin X", "group": "false_friend" },
    { "upper": "Ц", "lower": "ц", "sound": "ts", "anchor": "ts in cats", "group": "new" },
    { "upper": "Ч", "lower": "ч", "sound": "ch", "anchor": "ch in chair", "group": "new" },
    { "upper": "Ш", "lower": "ш", "sound": "sh", "anchor": "sh in shoe", "group": "new" },
    { "upper": "Щ", "lower": "щ", "sound": "shch", "anchor": "a long soft sh, as in fresh cheese run together", "group": "new" },
    { "upper": "Ъ", "lower": "ъ", "sound": "hard sign", "anchor": "no sound, a hard pause before the next vowel", "group": "new" },
    { "upper": "Ы", "lower": "ы", "sound": "y", "anchor": "the hard i, said with the tongue pulled back, near i in ill", "group": "new" },
    { "upper": "Ь", "lower": "ь", "sound": "soft sign", "anchor": "no sound, softens the letter before it", "group": "new" },
    { "upper": "Э", "lower": "э", "sound": "e", "anchor": "e in echo", "group": "new" },
    { "upper": "Ю", "lower": "ю", "sound": "yu", "anchor": "u in use", "group": "new" },
    { "upper": "Я", "lower": "я", "sound": "ya", "anchor": "ya in yard", "group": "new" }
  ]
